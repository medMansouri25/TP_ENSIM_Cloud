# Copy this file to .env and fill in the values.
# Local dev under Windows + Bun: use the STANDARD URI with tlsInsecure=true (workaround Bun bug)
# Production (Render / Linux): use the SRV URI without tlsInsecure

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
MONGO_DB_NAME=wordle
PORT=3000
